{
  "realm": "library",
  "enabled": true,

  "clients": [
    {
      "clientId": "spring-app",
      "enabled": true,
      "protocol": "openid-connect",

      "publicClient": true,
      "bearerOnly": false,

      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,

      "redirectUris": ["*"],
      "webOrigins": ["*"],

      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "jakarta-frontend",
      "enabled": true,
      "protocol": "openid-connect",

      "publicClient": true,
      "standardFlowEnabled": true,

      "redirectUris": ["http://localhost:8081/*"],
      "webOrigins": ["http://localhost:8081"],

      "attributes": {
        "pkce.code.challenge.method": ""
      },
      "protocolMappers": [
        {
          "name": "backend-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "spring-app",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],

  "users": [
    {
      "username": "user",
      "enabled": true,
      "email": "user@example.com",
      "firstName": "Demo",
      "lastName": "User",
      "emailVerified": true,

      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],

      "realmRoles": ["offline_access", "uma_authorization"],

      "clientRoles": {
        "spring-app": ["user"],
        "jakarta-frontend": ["user"]
      },

      "attributes": {
        "department": "development",
        "locale": "en"
      }
    },
    {
      "username": "librarian",
      "enabled": true,
      "email": "librarian@example.com",
      "firstName": "Demo",
      "lastName": "User",
      "emailVerified": true,

      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],

      "realmRoles": ["librarian", "offline_access", "uma_authorization"],

      "clientRoles": {
        "spring-app": ["user", "librarian"],
        "jakarta-frontend": ["user", "librarian"]
      },

      "attributes": {
        "department": "development",
        "locale": "en"
      }
    }
  ]
}
